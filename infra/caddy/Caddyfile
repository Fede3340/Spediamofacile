# =============================================================================
# CADDYFILE — Reverse proxy locale (split Laravel + Nuxt)
# =============================================================================
#
# Caddy su :8787 fa split routing:
#   /api/*  /sanctum/*  /storage/*  /auth/*  /webhooks/*  /stripe/*  → Laravel :8000
#   tutto il resto (HTML pagine, asset Nuxt)                          → Nuxt   :3001
#
#   Browser → Caddy (:8787) ─┬─ Laravel (:8000) per API/Sanctum/auth
#                            └─ Nuxt    (:3001) per pagine + asset
#
# Cookie cross-origin: stesso host (127.0.0.1:8787) → sessione condivisa.
# =============================================================================

:8787 {
  encode gzip

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
  }

  # Backend Laravel: API, Sanctum CSRF, storage, auth Google, webhook esterni.
  @api path /api/* /sanctum/* /storage/* /auth/* /webhooks/* /stripe/*
  reverse_proxy @api {$SF_BACKEND_PROXY_TARGET:127.0.0.1:8000} {
    header_up Host "127.0.0.1:8787"
    header_up X-Forwarded-Host "127.0.0.1:8787"
    header_up X-Forwarded-Port "8787"
    header_up X-Forwarded-Proto "{http.request.scheme}"
  }

  # Frontend Nuxt: tutto il resto (HTML pagine + asset).
  reverse_proxy {$SF_FRONTEND_PROXY_TARGET:127.0.0.1:3001} {
    header_up Host "127.0.0.1:8787"
    header_up X-Forwarded-Host "127.0.0.1:8787"
    header_up X-Forwarded-Port "8787"
    header_up X-Forwarded-Proto "{http.request.scheme}"
  }
}
