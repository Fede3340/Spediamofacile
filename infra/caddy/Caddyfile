# =============================================================================
# CADDYFILE — Reverse proxy locale (post-rewrite v2)
# =============================================================================
#
# Sito monolite Laravel + Inertia: tutto passa da Laravel su :8000.
# Caddy mantiene :8787 come endpoint storico locale per compat (URL preferito utente).
#
#   Browser → Caddy (:8787) → Laravel + Inertia (:8000)
#
# Vite HMR (in dev) gira separatamente su :5173 e si auto-inietta nelle pagine
# blade Inertia tramite @vite blade directive (nessun proxy necessario).
# =============================================================================

:8787 {
  encode gzip

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
  }

  # Tutto il sito (HTML Inertia + API + asset) → Laravel
  reverse_proxy {$SF_BACKEND_PROXY_TARGET:127.0.0.1:8000} {
    header_up Host "127.0.0.1:8787"
    header_up X-Forwarded-Host "127.0.0.1:8787"
    header_up X-Forwarded-Port "8787"
    header_up X-Forwarded-Proto "{http.request.scheme}"
  }
}
