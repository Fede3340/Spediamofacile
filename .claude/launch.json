{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "caddy-proxy",
      "runtimeExecutable": "caddy",
      "runtimeArgs": ["run", "--config", "infra/caddy/Caddyfile"],
      "port": 8787,
      "autoPort": false,
      "env": {
        "SF_FRONTEND_PROXY_TARGET": "127.0.0.1:3001",
        "SF_BACKEND_PROXY_TARGET": "127.0.0.1:8000"
      }
    },
    {
      "name": "nuxt-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nuxi", "dev", "--host", "127.0.0.1", "--port", "3001"],
      "port": 3001,
      "cwd": "apps/web",
      "autoPort": false
    },
    {
      "name": "nuxt-preview-mcp",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nuxi", "dev", "--host", "127.0.0.1", "--port", "3002"],
      "port": 3002,
      "cwd": "apps/web",
      "autoPort": false
    },
    {
      "name": "laravel-backend",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--host=127.0.0.1", "--port=8000"],
      "port": 8000,
      "cwd": "apps/api",
      "autoPort": false
    }
  ]
}
