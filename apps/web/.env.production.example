# =============================================================================
# VARIABILI D'AMBIENTE NUXT — PRODUZIONE
# =============================================================================
# Copia questo file come .env sul server prima di fare la build.
# Queste variabili vengono incorporate durante `npm run build`.
# =============================================================================

# URL base del backend — Caddy gestisce il proxy, quindi il frontend
# punta a se stesso (stesso dominio). Caddy smista /api/* a Laravel.
NUXT_PUBLIC_API_BASE=https://spediamofacile.it

# Chiave PUBBLICA Stripe (pk_live_...)
# La trovi su: https://dashboard.stripe.com/apikeys
NUXT_PUBLIC_STRIPE_KEY=pk_live_<CHIAVE_PUBBLICA_STRIPE>

# Modalita' produzione
NODE_ENV=production

# Pagine dev-only (es. /account/amministrazione/test-brt).
# In produzione mantenere false: la pagina ritorna 404.
# Attivare solo in staging o ambienti controllati.
NUXT_PUBLIC_ENABLE_DEV_TOOLS=false

# Sprint 7.3 — Analytics funnel.
# Plausible: GDPR-friendly, zero cookie, zero consent banner richiesto.
# Raccomandato per produzione. Lascia vuoto se non si vuole tracciare.
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=spediamofacile.it
#
# GA4: attivare SOLO se serve Google Ads o conversion tracking avanzato.
# Richiede Consent Mode v2 gestito dal CookieBanner.
NUXT_PUBLIC_GA_ID=
