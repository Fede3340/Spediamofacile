NUXT_PUBLIC_API_BASE=http://127.0.0.1:8787
# Dominio canonico del sito (usato per canonical, OG, schema.org, sitemap)
NUXT_PUBLIC_SITE_URL=https://spediamofacile.it
NUXT_PUBLIC_STRIPE_KEY=
# Pagine dev-only (es. /account/amministrazione/test-brt).
# false = 404 in produzione. true = accessibili (usare solo in staging o locale).
NUXT_PUBLIC_ENABLE_DEV_TOOLS=false

# Sprint 7.1 — Sentry FE error tracking + Core Web Vitals.
# Lascia vuoto in dev locale per NON inviare eventi (plugin diventa no-op).
# DSN si recupera da https://sentry.io/ → Project → Settings → Client Keys.
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENV=development
# Release impostata in CI (es. git sha). In dev locale tenere vuoto.
NUXT_PUBLIC_SENTRY_RELEASE=

# Sprint 7.3 — Analytics funnel (Plausible preferito, GA4 fallback).
# Entrambi opzionali: se vuoti, i plugin sono no-op (zero fetch, zero script).
#
# Plausible: privacy-first, no cookie → NESSUN consent banner richiesto.
# Dashboard su https://plausible.io — il dominio deve coincidere con il sito live.
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=
#
# GA4 (fallback): attivare SOLO se serve Google Ads / conversion tracking avanzato.
# Richiede Consent Mode v2 (gestito automaticamente da plugins/gtag.client.ts):
# default denied, upgrade granted via CookieBanner "Accetta tutti".
# Formato: G-XXXXXXXXXX
NUXT_PUBLIC_GA_ID=

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Sitekey PUBBLICA (frontend). Valori di test Cloudflare:
#   1x00000000000000000000AA → Pass sempre (default quando var vuota)
#   2x00000000000000000000AB → Blocca sempre (per QA error state)
#   3x00000000000000000000FF → Challenge interattiva forzata
# In produzione: usa la sitekey reale da https://dash.cloudflare.com/ → Turnstile.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ── Tawk.to live chat ─────────────────────────────────────────────────────────
# ARCHIVIATO 2026-04-20 (_archive/frontend-simplification-2026-04-20/npm-packages/tawk-to).
# Sostituito con mailto:supporto@spediamofacile.it nei canali di contatto pubblici.
# Per riattivare vedi README_REATTIVAZIONE.md nell'archivio.
# NUXT_PUBLIC_TAWKTO_ID=
# NUXT_PUBLIC_TAWKTO_WIDGET_ID=default
