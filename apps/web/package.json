{
  "name": "@spediamofacile/web",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "build": "node --max-old-space-size=6144 ./node_modules/@nuxt/cli/bin/nuxi.mjs build",
    "dev": "node --max-old-space-size=6144 ./node_modules/@nuxt/cli/bin/nuxi.mjs dev",
    "generate": "node --max-old-space-size=6144 ./node_modules/@nuxt/cli/bin/nuxi.mjs generate",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "lighthouse": "lhci autorun",
    "preview": "node --max-old-space-size=6144 ./node_modules/@nuxt/cli/bin/nuxi.mjs preview",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "typecheck": "nuxi prepare && node scripts/prepare-vue-typecheck.mjs && vue-tsc --noEmit -p tsconfig.json",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.2.1",
    "@nuxtjs/sitemap": "^8.0.11",
    "@nuxtjs/turnstile": "^1.1.2",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/vue": "^8.55.2",
    "@stripe/stripe-js": "^9.4.0",
    "@tailwindcss/vite": "^4.1.10",
    "leaflet": "^1.9.4",
    "nuxt": "^4.1.3",
    "nuxt-auth-sanctum": "^1.4.2",
    "nuxt-security": "^2.5.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.1.10",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.14.0",
    "@nuxt/eslint-config": "^1.15.2",
    "@playwright/test": "^1.58.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.2.1",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.8",
    "prettier": "^3.8.1",
    "ts-morph": "^28.0.0",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.6"
  }
}
