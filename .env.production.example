# =============================================================================
# VARIABILI D'AMBIENTE — PRODUZIONE
# =============================================================================
# Copia questo file come .env sul server e compila TUTTI i valori.
# I segnaposto tra parentesi angolari <...> DEVONO essere sostituiti.
# =============================================================================

# ------------------------------------------------------------------
# Applicazione
# ------------------------------------------------------------------
APP_NAME=SpediamoFacile
APP_ENV=production
# Genera con: php artisan key:generate
APP_KEY=
# MAI true in produzione — espone stack trace e dati sensibili
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome
# URL pubblico del backend (quello che Caddy espone)
APP_URL=https://spediamofacile.it
# URL del frontend Nuxt (serve per email, link di reset password, ecc.)
APP_FRONTEND_URL=https://spediamofacile.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Costo computazionale hash password — 12 e' un buon default per produzione
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------
# Log — in produzione "stack" scrive su file + canale aggiuntivo
# ------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Usa "warning" o "error" in produzione per ridurre rumore
LOG_LEVEL=warning

# ------------------------------------------------------------------
# Database MySQL
# ------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Nome del database — crealo prima: CREATE DATABASE spediamofacile;
DB_DATABASE=spediamofacile
DB_USERNAME=<UTENTE_MYSQL>
DB_PASSWORD=<PASSWORD_MYSQL>

# ------------------------------------------------------------------
# Sessione — cookie sicuro via HTTPS
# ------------------------------------------------------------------
# database (tabella "sessions") scelto invece di redis: sessione sopravvive
# a riavvio Redis e non richiede sticky sessions sul load balancer.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Dominio del cookie — punto davanti per includere sottodomini
SESSION_DOMAIN=.spediamofacile.it
# OBBLIGATORIO in produzione — i cookie viaggiano solo su HTTPS
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ------------------------------------------------------------------
# Cache, code, filesystem
# ------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# redis: job async (email, BRT webhook, notifiche wallet). Richiede Redis UP.
# Fallback: se Redis e' down, Laravel throwa ConnectionException sul dispatch.
# Per degradare graceful (job inline) settare QUEUE_CONNECTION=sync temporaneamente.
QUEUE_CONNECTION=redis
# Redis anche per cache: hit/miss ~1ms vs ~10ms del driver file.
CACHE_STORE=redis
CACHE_PREFIX=spediamofacile_

# ------------------------------------------------------------------
# Redis — managed (Render Key Value / self-hosted)
# ------------------------------------------------------------------
# Su Render: REDIS_HOST/PORT/PASSWORD popolati automaticamente da render.yaml
# tramite fromService. Self-hosted: installare redis-server e impostare i valori.
REDIS_CLIENT=phpredis
REDIS_HOST=<HOST_REDIS_MANAGED>
REDIS_PORT=6379
REDIS_PASSWORD=<PASSWORD_REDIS>
# DB separati: queue su 0, cache su 1. Evita che FLUSHDB cache cancelli job.
REDIS_DB=0
REDIS_CACHE_DB=1

# ------------------------------------------------------------------
# Queue worker — Supervisor locale
# ------------------------------------------------------------------
# true: supervisord avvia 2 worker "laravel-worker" nel container.
# false: worker esterno (es. servizio Render "spedizionefacile-queue").
ENABLE_QUEUE_WORKER=false

# ------------------------------------------------------------------
# Sanctum — autenticazione SPA con cookie
# ------------------------------------------------------------------
# Domini che possono inviare cookie di sessione (senza https://)
SANCTUM_STATEFUL_DOMAINS=spediamofacile.it,www.spediamofacile.it

# ------------------------------------------------------------------
# CORS — origini ammesse per richieste con credenziali
# ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://spediamofacile.it,https://www.spediamofacile.it

# ------------------------------------------------------------------
# Email — Resend (driver nativo consigliato, no auth SMTP fragile)
# ------------------------------------------------------------------
# Preferire il driver "resend" (API HTTPS): piu' affidabile, niente risk
# di blocco porta 465, retry automatici, webhooks bounce nativi.
# 1. Registrati su https://resend.com
# 2. Verifica il dominio spediamofacileaccount.com (SPF+DKIM+DMARC)
# 3. Crea API Key e incollala come RESEND_KEY
MAIL_MAILER=resend
RESEND_KEY=<RE_API_KEY_RESEND>
MAIL_FROM_ADDRESS="noreply@spediamofacileaccount.com"
MAIL_FROM_NAME="${APP_NAME}"
# Fallback SMTP (se necessario) — lasciare commentato in produzione
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=<RE_API_KEY_RESEND>
# MAIL_ENCRYPTION=ssl

# ------------------------------------------------------------------
# BRT (Bartolini) — Credenziali spedizioni PRODUCTION
# ------------------------------------------------------------------
# Sandbox vs Production: cambiano URL e credentials.
# BRT_ENV=production attiva strict mode in app/Services/Brt/ (no mock, no fallback).
# Dettagli completi: docs/BRT_PRODUCTION_SETUP.md
BRT_ENV=production
# URL base production (sandbox: https://sandbox.brt.it/...)
BRT_API_BASE_URL=https://api.brt.it/rest/v1/
BRT_API_URL=https://api.brt.it/rest/v1/shipments
# Credentials production — dal referente BRT Business, diverse dalla sandbox
BRT_CLIENT_ID=<ID_CLIENTE_BRT_PROD>
BRT_PASSWORD=<PASSWORD_BRT_PROD>
# PUDO (Punti di Ritiro): API + token SEPARATI dal main BRT
BRT_PUDO_API_URL=https://api.brt.it
BRT_PUDO_TOKEN=<TOKEN_PUDO_BRT_PROD>
# Filiale di partenza (codice numerico fornito dal referente)
BRT_DEPARTURE_DEPOT=0
# In produzione DEVE essere true — verifica certificati SSL
BRT_VERIFY_SSL=true
# Pickup API: lasciare false finche BRT non fornisce endpoint contrattuale valido.
BRT_PICKUP_ENABLED=false
BRT_PICKUP_ENDPOINT=
# Webhook tracking push (BRT → backend). HMAC-SHA256 su header X-Brt-Signature.
# Genera con: openssl rand -hex 32 — stesso valore sul portale BRT.
BRT_WEBHOOK_SECRET=<SEGRETO_HMAC_32_HEX>
# IP sorgenti BRT push (CSV). Forniti dal referente per hardening aggiuntivo.
BRT_WEBHOOK_ALLOWED_IPS=

# ------------------------------------------------------------------
# Sentry — Error tracking + performance (OBBLIGATORIO in produzione)
# ------------------------------------------------------------------
# Senza Sentry, gli errori 500 in produzione scompaiono nel vuoto.
# Crea progetto su https://sentry.io → Laravel
# Piano team: 50k events/mese a 26€/mese (consigliato go-live)
SENTRY_LARAVEL_DSN=<DSN_PROGETTO_SENTRY>
# Popolato da CI deploy.yml (GIT SHA breve, es. "abc1234")
SENTRY_RELEASE=<GIT_SHA_O_VERSIONE>
# 10% delle richieste tracciate per performance monitoring
SENTRY_TRACES_SAMPLE_RATE=0.1
# Profiling: tenere 0.0 salvo debug mirati (costoso CPU + quota)
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Tracing Redis/queue: off di default (attivabili on-demand)
SENTRY_TRACE_QUEUE_ENABLED=false
SENTRY_TRACE_REDIS_ENABLED=false

# ------------------------------------------------------------------
# Stripe — Pagamenti LIVE (production)
# ------------------------------------------------------------------
# pk_live_ / sk_live_ da https://dashboard.stripe.com/apikeys
# (toggle "View test data" OFF). NON committare MAI chiavi reali nel repo:
# settare direttamente su Render env vars.
# Dettagli completi: docs/STRIPE_LIVE_SETUP.md
STRIPE_KEY=pk_live_<CHIAVE_PUBBLICA_STRIPE>
STRIPE_SECRET=sk_live_<CHIAVE_SEGRETA_STRIPE>
# Stripe Connect (Partner Pro) — Client ID ca_... da Connect → Settings
STRIPE_CLIENT_ID=<CLIENT_ID_STRIPE_CONNECT>
# Webhook signing secret: Dashboard → Developers → Webhooks → endpoint → Reveal
# URL webhook registrato: https://spediamofacile.it/api/stripe/webhook
# Eventi: payment_intent.succeeded, payment_intent.payment_failed,
#         account.updated, account.application.deauthorized, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_<SEGRETO_WEBHOOK_STRIPE>

# ------------------------------------------------------------------
# Google OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# ------------------------------------------------------------------
# Facebook OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/facebook/callback

# ------------------------------------------------------------------
# Apple OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/auth/apple/callback
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ------------------------------------------------------------------
# AWS S3 (opzionale — per storage file su cloud)
# ------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
